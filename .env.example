# Copy to .env and fill in. NEVER commit the real .env.

# Gmail OAuth (from `python auth_setup.py`)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Gemini / Gemma (free key: https://aistudio.google.com/apikey)
# Default model is Gemma 4 — free of charge on the Gemini API. Leave blank to
# skip AI entirely and use the built-in free heuristic sorter.
GEMINI_API_KEY=
GEMINI_MODEL=gemma-4-31b-it

# Telegram (@BotFather for token, @userinfobot for chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Behavior
DIGEST_TIMEZONE=Asia/Kolkata
BODY_TRUNCATE=500
SEND_ON_EMPTY=true
